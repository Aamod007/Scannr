# Blockchain Service Configuration
PORT=5000
NODE_ENV=development

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Hyperledger Fabric
FABRIC_CHANNEL=scannr-channel
FABRIC_CHAINCODE=importer-profile
FABRIC_AUDIT_CHAINCODE=audit-trail
FABRIC_IDENTITY=admin
FABRIC_DISCOVERY=true
FABRIC_AS_LOCALHOST=true
FABRIC_QUERY_TIMEOUT=30000
FABRIC_SUBMIT_TIMEOUT=60000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8006

# Logging
LOG_LEVEL=info
