# Computer Vision Service Configuration
PORT=5001
HOST=0.0.0.0
DEBUG=false

# Model
MODEL_PATH=models/yolov8x-customs-v2.3.pt
MODEL_VERSION=yolov8x-customs-v2.3
CONFIDENCE_THRESHOLD=0.70
INPUT_SIZE=1280

# S3 / MinIO (object storage for scans and heatmaps)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_XRAY_BUCKET=xray-scans
S3_GRADCAM_BUCKET=gradcam-maps
S3_MODEL_BUCKET=ml-models

# Local fallback storage (when S3 is unavailable)
LOCAL_STORAGE_PATH=storage

# Database (for saving scan results)
POSTGRES_URL=postgresql://scannr:scannr@localhost:5432/scannr

# RabbitMQ (for publishing to risk-scoring-queue)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RISK_SCORING_QUEUE=risk-scoring-queue

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
